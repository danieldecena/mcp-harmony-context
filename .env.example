# Copy to .env and edit. The server reads this on startup.
#
# Option A — point at a local Harmony install:
# HARMONY_HELP_PATH=/Applications/Toon Boom Harmony 25.2 Premium/Harmony 25.2 Premium.app/Contents/tba/resources/help
#
# Option B — mirror the public docs first (`uv run scripts/fetch_harmony_docs.py`),
# then point at the local copy:
# HARMONY_HELP_PATH=/absolute/path/to/mcp-harmony-context/harmony-help

HARMONY_HELP_PATH=
